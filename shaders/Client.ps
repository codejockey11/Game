#include "Client.hlsl"
#include "Samplers.hlsl"
#include "Functions.hlsl"

float4 main(SPixel vs) : SV_Target0
{
    float4 final = gTextureMaps[0].Sample(gsamLinearWrap, vs.uv);
    
    float a = final.a;
    
    final.rgb = lerp(float3(m_ambient.r, m_ambient.g, m_ambient.b), float3(m_diffuse.r, m_diffuse.g, m_diffuse.b), final.rgb);

    final.rgb *= float3(m_emissive.r, m_emissive.g, m_emissive.b);
    
    final.a = a;
    
    return final;
}