#include "Static.hlsl"
#include "Samplers.hlsl"
#include "Functions.hlsl"

float4 main(SPixel vs) : SV_Target0
{
    float4 final = gTextureMaps[0].Sample(gsamLinearWrap, vs.uv);
    
    float a = final.a;
    
    if (hasmap_d == 1)
    {
        a = gTextureMaps[1].Sample(gsamLinearWrap, vs.uv).r;
    }
    
    if (hasmap_bump == 1)
    {
        final.rgb *= gTextureMaps[2].Sample(gsamLinearWrap, vs.uv).rgb;
    }
    
    final.rgb *= float3(m_diffuse.r, m_diffuse.g, m_diffuse.b);
    
    final.a = a * m_opticalDensity;
    
    return final;
}